# ── Configuración del servidor ──────────────────────────────
PORT=5000
NODE_ENV=development

# ── Base de datos ─────────────────────────────────────────────
# MongoDB local:
MONGO_URI=mongodb://localhost:27017/voyproject
# MongoDB Atlas (producción):
# MONGO_URI=mongodb+srv://<usuario>:<password>@cluster.mongodb.net/voyproject

# ── JWT ───────────────────────────────────────────────────────
# IMPORTANTE: Cambiar por un string largo y aleatorio en producción
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=reemplaza_esto_con_un_secreto_seguro_de_al_menos_64_caracteres
JWT_EXPIRES_IN=30d
